---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="About">
  <Navbar />

  <main>
    <HeroSection
      title="About Us"
      subtitle="CodingCup Labs is a digital agency that believes in the power of structural design and robust engineering."
    />

    <section class="section">
      <div class="container content">
        <h2>Our Philosophy</h2>
        <p>We believe in "Minimal Neobrutalism" — a design approach that strips away chaos, opting for structural, honest environments. We celebrate raw engineering through visible borders and high contrast.</p>

        <p>Our team is dedicated to building interfaces that are not only beautiful but also accessible, performant, and reliable.</p>

        <h3>The Team</h3>
        <p>We are a small, focused group of engineers and designers who care deeply about the craft of software development.</p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .content {
    max-width: 800px;
  }

  .content h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .content h3 {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .content p {
    margin-bottom: var(--space-md);
    font-size: var(--text-base);
  }
</style>
