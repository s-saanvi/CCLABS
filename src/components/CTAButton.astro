---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}${href.startsWith('/') ? href.slice(1) : href}`} class={`btn btn-${variant} ${className}`}>
  <slot />
</a>

<style>
  .btn {
    padding: 12px 24px;
    font-size: var(--text-sm);
  }
</style>
